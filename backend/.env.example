DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5436/lexscale
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4.1-mini
# Optional: model dedicated to upload case analysis (fallback: OPENAI_MODEL)
# OPENAI_CASE_ANALYSIS_MODEL=gpt-4.1
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIMENSIONS=1536
# Full-document case analysis tuning
CASE_AI_FULL_DOCUMENT_ENABLED=true
CASE_AI_CHUNK_SIZE=14000
CASE_AI_CHUNK_OVERLAP=1200
CASE_AI_MAX_CHUNKS=8
CASE_AI_TEMPERATURE=0
CASE_AI_MAX_OUTPUT_TOKENS=2200
CASE_AI_MIN_TEXT_CHARS=300
# Optional: override pricing (USD) for usage estimation in logs
# OPENAI_PRICING_GPT_4_1_MINI_INPUT_PER_1M=0.40
# OPENAI_PRICING_GPT_4_1_MINI_OUTPUT_PER_1M=1.60
# OPENAI_PRICING_TEXT_EMBEDDING_3_SMALL_INPUT_PER_1M=0.02
# OPENAI_PRICING_DEFAULT_INPUT_PER_1M=0.0
# OPENAI_PRICING_DEFAULT_OUTPUT_PER_1M=0.0
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
CORS_ORIGINS=http://localhost:5000,http://127.0.0.1:5000,http://localhost:5177,http://127.0.0.1:5177
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAMESITE=lax
AUTH_COOKIE_NAME=lexscale_session
SESSION_TTL_HOURS=168
PUBLIC_SYNC_TJDFT_QUERY=direito civil
PUBLIC_SYNC_TJDFT_PAGE_SIZE=40
# dados.gov.br (conector piloto)
# DADOS_GOV_BR_API_KEY=seu_token_chave_api_dados_abertos
DADOS_GOV_BR_PILOT_QUERY=justica
DADOS_GOV_BR_PAGE=1
# DADOS_GOV_BR_DATASET_ID=
# DADOS_GOV_BR_RESOURCE_ID=
DADOS_GOV_BR_PILOT_MAX_ITEMS=50
# Public data sync scheduler
PUBLIC_DATA_SYNC_INTERVAL_MINUTES=60
PUBLIC_DATA_SYNC_RUN_ON_STARTUP=true
# Also trigger sync before each upload analysis (in async worker)
PUBLIC_DATA_SYNC_ON_CASE_PROCESSING=true
# 0 = force sync on every upload; >0 = sync only if data is older than this threshold
PUBLIC_DATA_SYNC_CASE_MIN_FRESHNESS_MINUTES=0
